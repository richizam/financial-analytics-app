generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums: Autenticación ──────────────────────────────────────────────────────

enum UserRole {
  admin
  contador
  auditor
  gerente
}

// ─── Enums: Empresa ────────────────────────────────────────────────────────────

enum TipoContribuyente {
  sociedad
  persona_natural_obligada
  persona_natural_no_obligada
}

enum CompanyClass {
  grande
  mediana
  pequena
  microempresa
}

enum NiifFramework {
  niif_completas
  niif_pymes
  rimpe
}

enum RegimenTributario {
  general
  rimpe_microempresa
  rimpe_negocio_popular
  regimen_especial
}

enum SectorEconomico {
  comercial
  servicios
  industrial
  construccion
  agricola
  financiero
  salud
  educacion
  tecnologia
  transporte
  minero_petroleo
  otro
}

enum MetodoInventario {
  promedio_ponderado
  fifo
}

enum MetodoDepreciacion {
  lineal
  unidades_produccion
  saldo_decreciente
}

enum ModeloPPE {
  costo
  revaluacion
}

enum FuenteDatos {
  excel
  powerbi
  ambos
}

// ─── NextAuth: Account ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── NextAuth: Session ─────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NextAuth: VerificationToken ──────────────────────────────────────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Modelo: User ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  companies UserCompany[]
  auditLogs AuditLog[]
}

// ─── Modelo: Company ───────────────────────────────────────────────────────────

model Company {
  id                           String             @id @default(cuid())
  razonSocial                  String
  nombreComercial              String?
  ruc                          String             @unique
  tipoContribuyente            TipoContribuyente
  representanteLegal           String?
  correoContacto               String?
  telefonoContacto             String?
  activosTotalesUSD            Int?
  ingresosUSD                  Int?
  numeroEmpleados              Int?
  clasificacion                CompanyClass
  cotizaEnBolsa                Boolean            @default(false)
  esEntidadFinanciera          Boolean            @default(false)
  tieneObligacionPublica       Boolean            @default(false)
  niifFramework                NiifFramework
  regimenTributario            RegimenTributario
  obligadoContabilidad         Boolean            @default(true)
  agenteRetencion              Boolean            @default(false)
  contribuyenteEspecial        Boolean            @default(false)
  resolucionContribEspecial    String?
  sector                       SectorEconomico
  mesInicioEjercicio           Int                @default(1)
  monedaFuncional              String             @default("USD")
  tieneInventarios             Boolean            @default(false)
  tieneActivosFijos            Boolean            @default(true)
  tieneArrendamientos          Boolean            @default(false)
  tieneBeneficiosEmpleados     Boolean            @default(false)
  tieneInstrumentosFinancieros Boolean            @default(false)
  tieneMonedaExtranjera        Boolean            @default(false)
  tieneSubsidiarias            Boolean            @default(false)
  metodoInventarios            MetodoInventario?
  metodoDepreciacion           MetodoDepreciacion @default(lineal)
  modeloMedicionPPE            ModeloPPE          @default(costo)
  fuenteDatos                  FuenteDatos
  pbiWorkspaceId               String?
  pbiDatasetId                 String?
  active                       Boolean            @default(true)
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  users UserCompany[]
}

// ─── Modelo: UserCompany ───────────────────────────────────────────────────────

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

// ─── Modelo: AuditLog ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
