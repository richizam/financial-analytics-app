# Copy to .env before deploying to a VPS, or export these variables in your shell.

NGINX_PORT=8080

POSTGRES_DB=financial_analytics
POSTGRES_USER=financial
POSTGRES_PASSWORD=change-this-postgres-password

BACKEND_API_KEY=change-this-long-random-backend-key
NEXTAUTH_SECRET=change-this-long-random-nextauth-secret
NEXTAUTH_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

DEMO_USER=demo
DEMO_PASSWORD=change-this-demo-password

# Optional OAuth providers.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional Grok/xAI integration. Keep this server-side only.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_TIMEOUT_SECONDS=45
