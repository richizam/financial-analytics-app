# Copy to .env before running Docker locally or deploying to a VPS.

NGINX_PORT=8080

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

BACKEND_API_KEY=change-this-long-random-backend-key
CORS_ORIGINS=http://localhost:8080

# Optional Grok/xAI integration. Keep this server-side only.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_REASONING_EFFORT=medium
XAI_TIMEOUT_SECONDS=45
