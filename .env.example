NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

PYTHON_BACKEND_URL=http://127.0.0.1:8000

APP_ENV=local
BACKEND_STORAGE=db
BACKEND_REQUIRE_API_KEY=false
BACKEND_API_KEY=
DATA_ROOT=data/empresas
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Postgres connection string. Use the pooled connection string from
# the Supabase dashboard for VPS/container deployments.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
# Direct (session-mode, port 5432) connection used ONLY by the LangGraph
# checkpointer. The transaction-mode pooler (6543) breaks prepared statements;
# set this to the direct connection string when AI_ORCHESTRATOR=langgraph.
# Optional — falls back to DATABASE_URL (with prepared statements disabled).
DATABASE_URL_DIRECT=
LANGGRAPH_CHECKPOINT_SCHEMA=app_private
SUPABASE_AUTH_REQUIRED=false

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_REASONING_EFFORT=medium
XAI_TIMEOUT_SECONDS=45

# AI orchestrator: "legacy" (hand-rolled loop) or "langgraph" (graph with retry,
# tool-error self-correction, clarification, and Postgres-checkpointed threads).
# Production compose defaults to langgraph; set legacy only if you need rollback.
AI_ORCHESTRATOR=langgraph
